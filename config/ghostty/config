font-family = FiraCode Nerd Font Mono
font-family-bold = FiraCode Nerd Font Mono Bold
font-family-italic = FiraCode Nerd Font Mono Italic
font-family-bold-italic = FiraCode Nerd Font Mono Bold Italic

font-synthetic-style = true

font-size = 16

theme = catppuccin-mocha
window-colorspace = display-p3
window-theme = dark
bold-is-bright = true
cursor-style-blink = false

mouse-hide-while-typing = true

window-decoration = true

macos-option-as-alt = true

clipboard-read = allow
clipboard-write = allow
copy-on-select = true

keybind = global:cmd+/=toggle_quick_terminal

keybind = alt+ctrl+v=new_split:right
keybind = alt+ctrl+s=new_split:down

keybind = alt+ctrl+h=goto_split:left
keybind = alt+ctrl+l=goto_split:right
keybind = alt+ctrl+j=goto_split:bottom
keybind = alt+ctrl+k=goto_split:top
keybind = alt+ctrl+z=toggle_split_zoom

keybind = alt+ctrl+e=equalize_splits

keybind = super+ctrl+j=resize_split:down,30
keybind = super+ctrl+k=resize_split:up,30
keybind = super+ctrl+h=resize_split:left,30
keybind = super+ctrl+l=resize_split:right,30
