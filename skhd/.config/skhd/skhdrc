#change window focus within space
alt + ctrl - j : yabai -m window --focus south
alt + ctrl - k : yabai -m window --focus north
alt + ctrl - h : yabai -m window --focus west
alt + ctrl - l : yabai -m window --focus east

#change focus between external displays (left and right)
alt + ctrl - p: yabai -m display --focus west
alt + ctrl - n: yabai -m display --focus east

# rotate layout clockwise
cmd + ctrl - r : yabai -m space --rotate 273

# flip along y-axis
cmd + ctrl - y : yabai -m space --mirror y-axis

# flip along x-axis
cmd + ctrl - x : yabai -m space --mirror x-axis

# toggle window float
cmd + ctrl - f : yabai -m window --toggle float --grid 4:4:1:1:2:2

# maximize a window
cmd + ctrl - m : yabai -m window --toggle zoom-fullscreen

# balance out tree of windows (resize to occupy same area)
cmd + ctrl - e : yabai -m space --balance

# swap windows
cmd + ctrl - j : yabai -m window --swap south
cmd + ctrl - k : yabai -m window --swap north
cmd + ctrl - h : yabai -m window --swap west
cmd + ctrl - l : yabai -m window --swap east

# move window to display left and right
cmd + ctrl - p : yabai -m window --display west; yabai -m display --focus west;
cmd + ctrl - n : yabai -m window --display east; yabai -m display --focus east;

# move window to space #
cmd + ctrl - 1 : yabai -m window --space 1;
cmd + ctrl - 2 : yabai -m window --space 2;
cmd + ctrl - 3 : yabai -m window --space 3;
cmd + ctrl - 4 : yabai -m window --space 4;
cmd + ctrl - 5 : yabai -m window --space 5;
cmd + ctrl - 6 : yabai -m window --space 6;
cmd + ctrl - 7 : yabai -m window --space 7;
cmd + ctrl - 8 : yabai -m window --space 8;
cmd + ctrl - 9 : yabai -m window --space 9;
cmd + ctrl - 0 : yabai -m window --space 10;

# stop/start/restart yabai
ctrl + shift - q : yabai --stop-service
ctrl + shift - s : yabai --start-service
ctrl + shift - r : yabai --restart-service
